---
layout: layouts/layout.njk
title: Články
---

<h2>Články</h2>

{% for article in collections.clanky | reverse %}
  {% if article.url != "/clanky/" %}
  <h3>
      <a href="{{ article.url }}">{{ article.data.title }}</a>
      <span class="rightpost">{{ article.data.meta }}</span>
  </h3>

  <p class="bottompost">
      přidal: {{ article.data.author }}
      | přidáno: {{ article.data.date | dateFilter }}
  </p>
  {% endif %}
{% endfor %}
